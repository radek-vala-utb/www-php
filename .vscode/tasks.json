{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Spustit PHP server",
      "type": "shell",
      "command": "php",
      "args": ["-S", "0.0.0.0:8000"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "php-server",
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Development Server.*started.*",
          "endsPattern": ".*Development Server.*started.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
